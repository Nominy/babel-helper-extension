# Local Chrome Web Store publishing credentials.
# Copy to .env.cws.local and fill in real values before running local publish helpers.

CWS_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
CWS_CLIENT_SECRET=your-google-oauth-client-secret
CWS_REFRESH_TOKEN=your-refresh-token

# Optional short-lived fallback used only when refresh credentials are unavailable.
CWS_ACCESS_TOKEN=

# Either keep the full item URL...
CWS_ITEM_URL=https://chromewebstore.googleapis.com/v2/publishers/your-publisher-id/items/your-extension-id

# ...or set these directly.
# CWS_PUBLISHER_ID=your-publisher-id
# CWS_EXTENSION_ID=your-extension-id
