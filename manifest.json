{
  "manifest_version": 3,
  "name": "Babel Audio Workflow Helper",
  "version": "1.0.45",
  "description": "Workflow shortcuts and quick actions for the Babel Audio transcription dashboard.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://dashboard.babel.audio/*"
      ],
      "js": [
        "dist/content/entry.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dist/content/magnifier-bridge.js",
        "dist/content/playback-bridge.js",
        "dist/content/timestamp-bridge.js",
        "dist/content/linter-bridge.js",
        "dist/content/quick-region-autocomplete-bridge.js"
      ],
      "matches": [
        "https://dashboard.babel.audio/*"
      ]
    }
  ]
}
