{
  "manifest_version": 3,
  "name": "Babel Audio Workflow Helper",
  "version": "0.1.0",
  "description": "Workflow shortcuts and quick actions for the Babel Audio transcription dashboard.",
  "content_scripts": [
    {
      "matches": [
        "https://dashboard.babel.audio/transcription*",
        "https://dashboard.babel.audio/transcription/*"
      ],
      "js": [
        "content/shared.js",
        "content/rows.js",
        "content/cut.js",
        "content/mangifier.js",
        "content/hotkeys.js",
        "content/main.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/mangifier-bridge.js"
      ],
      "matches": [
        "https://dashboard.babel.audio/*"
      ]
    }
  ]
}
