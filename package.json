{
  "name": "babel-helper-extension",
  "version": "1.0.92",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "npm run version:patch && npm run build:core && npm run sync:unpacked",
    "build:reload": "npm run build",
    "build:core": "node esbuild.config.mjs",
    "build:watch": "node esbuild.config.mjs --watch",
    "build:zip": "node scripts/pack.mjs",
    "sync:unpacked": "node scripts/sync-unpacked.mjs",
    "version:patch": "node scripts/increment-version.mjs",
    "publish:cws": "node scripts/publish-cws.mjs",
    "setup:github-secrets": "node scripts/setup-github-secrets.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.25.1",
    "typescript": "^5.8.2"
  },
  "dependencies": {}
}
